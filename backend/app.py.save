@app.route('/etudiant/notes')
@login_required
@role_required('[ETUDIANT]')
def etudiant_notes():
    notes = current_user.notes

    # ── Moyenne générale ──
    total_coeffs = sum(n.coefficient for n in notes)
    moyenne = round(sum(n.valeur * n.coefficient for n in notes) / total_coeffs, 2) if total_coeffs > 0 else None

    # ── Moyenne par matière ──
    moyennes_par_matiere = {}
    notes_par_matiere = defaultdict(list)
    for n in notes:
        notes_par_matiere[n.matiere].append(n)
    for matiere, ns in notes_par_matiere.items():
        tp = sum(n.valeur * n.coefficient for n in ns)
        tw = sum(n.coefficient for n in ns)
        moyennes_par_matiere[matiere] = round(tp / tw, 2) if tw else 0

    # ── Données radar ──
    matieres_data = defaultdict(list)
    for n in notes:
        matieres_data[n.matiere].append({
            "valeur": float(n.valeur),
            "coefficient": float(n.coefficient)
        })

# ── Données évolution ligne ──
    notes_triees = sorted(notes, key=lambda n: n.id)
    labels, moyennes_etudiant = [], []
    total_pts, total_poids = 0, 0
    for i, n in enumerate(notes_triees, 1):
        total_pts   += n.valeur * n.coefficient
        total_poids += n.coefficient
        labels.append(f"Éval {i}")
        moyennes_etudiant.append(round(total_pts / total_poids, 2))

    toutes_notes = Note.query.order_by(Note.id).all()
    moyennes_classe = []
    for n_eleve in notes_triees:
        notes_avant = [n for n in toutes_notes if n.id <= n_eleve.id]
        tp = sum(n.valeur * n.coefficient for n in notes_avant)
        tw = sum(n.coefficient for n in notes_avant)
        moyennes_classe.append(round(tp / tw, 2) if tw else 0)

    # C'est ici que l'alignement doit être parfait (4 espaces)
    evolution_data = {
        "labels": labels,
        "etudiant": moyennes_etudiant,
        "classe": moyennes_classe
    }

    return render_template('notes.html',
                           moyenne=moyenne,
                           total_coeffs=total_coeffs,
                           moyennes_par_matiere=moyennes_par_matiere,
                           evolution_data=evolution_data,
                           matieres_data=dict(matieres_data))

# ── API : moyenne de classe pour une note spécifique ──
@app.route('/api/note/<int:note_id>/moyenne-classe')
@login_required
@role_required('[ETUDIANT]')
def api_moyenne_classe_note(note_id):
    # Vérifie que la note appartient bien à l'étudiant connecté
    note = Note.query.filter_by(id=note_id, etudiant_id=current_user.id).first()
    if not note:
        abort(404)

    # Toutes les notes de la même matière pour tous les étudiants
    notes_matiere = Note.query.filter_by(matiere=note.matiere).all()
    if not notes_matiere:
        return jsonify({"moyenne_classe": None, "nb_eleves": 0})

    tp = sum(n.valeur * n.coefficient for n in notes_matiere)
    tw = sum(n.coefficient for n in notes_matiere)
    moyenne_classe = round(tp / tw, 2) if tw else 0
    nb_eleves = len(set(n.etudiant_id for n in notes_matiere))

    return jsonify({
        "moyenne_classe": moyenne_classe,
        "nb_eleves": nb_eleves,
        "matiere": note.matiere,
        "ma_note": note.valeur
    })

