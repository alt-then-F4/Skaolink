@app.route('/prof/classes/<int:class_id>/student/<int:student_id>/note', methods=['POST'])
@login_required
@role_required('[PROF]', '[ADMIN]')
def prof_saisir_note(class_id, student_id):
    nom_eval = request.form.get('evaluation_nom')
    matiere = request.form.get('matiere')
    valeur = float(request.form.get('valeur'))
    sur = float(request.form.get('sur', 20))

    # 1. On cherche si l'évaluation existe déjà, sinon on la crée
    evaluation = Evaluation.query.filter_by(nom=nom_eval, matiere=matiere).first()
    if not evaluation:
        evaluation = Evaluation(nom=nom_eval, matiere=matiere)
        db.session.add(evaluation)
        db.session.flush() # Pour récupérer l'ID de la nouvelle évaluation

    # 2. On crée la note pour l'étudiant
    nouvelle_note = Note(
        valeur=valeur, 
        sur=sur, 
        etudiant_id=student_id, 
        evaluation_id=evaluation.id
    )
    db.session.add(nouvelle_note)
    db.session.commit()
    
    return redirect(url_for('prof_classe_detail', id=class_id))

@app.route('/prof/classes/<int:class_id>/student/<int:student_id>/absence', methods=['POST'])
@login_required
@role_required('[PROF]', '[ADMIN]')
def prof_saisir_absence(class_id, student_id):
    motif = request.form.get('motif')
    duree = int(request.form.get('duree'))
    date_str = request.form.get('date')
    
    # On convertit la date textuelle (HTML) en vrai objet Date Python
    date_obj = datetime.strptime(date_str, '%Y-%m-%d').date() if date_str else datetime.utcnow().date()

    # On crée l'absence
    nouvelle_absence = Absence(
        etudiant_id=student_id, 
        motif=motif, 
        duree=duree, 
        date=date_obj
    )
    db.session.add(nouvelle_absence)
    db.session.commit()
    
    return redirect(url_for('prof_classe_detail', id=class_id))


